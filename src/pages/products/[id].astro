---
import Layout from "../../components/Layout.astro";
import AddToCart from "../../components/AddToCart.vue";
import CartIcon from "../../components/CartIcon.vue";
import { getLiveEntry } from "astro:content";

const { id } = Astro.params;
const { entry, error } = await getLiveEntry("products", id!);

if (error || !entry) {
  return Astro.redirect("/404");
}
Astro.cache.set(entry);

const product = entry?.data;
---

<Layout title={product?.name ?? "Product"}>
  <CartIcon client:load slot="header-right" />
  {
    !product ? (
      <div class="error">
        <p>Product not found.</p>
        <a href="/">Back to shop</a>
      </div>
    ) : (
      <div class="product-page">
        <a href="/" class="back">
          &larr; Back to shop
        </a>

        <div class="product-layout">
          <div class="product-image">
            <img src={product.image} alt={product.name} />
          </div>

          <div class="product-info">
            <span class="category">{product.category}</span>
            <h1>{product.name}</h1>
            <p class="description">{product.description}</p>

            <div class="price-block">
              <span class="price">
                {new Intl.NumberFormat("nl-NL", {
                  style: "currency",
                  currency: "EUR",
                }).format(product.price)}
              </span>
              <span class={`stock ${product.inStock ? "in" : "out"}`}>
                {product.inStock ? "In stock" : "Sold out"}
              </span>
            </div>

            {product.inStock && (
              <AddToCart
                client:visible
                productId={product.id}
                productName={product.name}
              />
            )}

            {!product.inStock && (
              <button class="disabled-btn" disabled>
                Out of Stock
              </button>
            )}
          </div>
        </div>

        <div class="debug">
          <div class="debug-inner">
            <span class="debug-label">Cache</span>
            <span>
              Rendered at:{" "}
              <code>
                {new Date().toLocaleTimeString("en-GB", { hour12: false })}
              </code>
            </span>
            <span>
              Tags:{" "}
              <code>{Astro.cache.options.tags?.join(", ") || "none"}</code>
            </span>
            <span>
              Last modified:{" "}
              <code>
                {Astro.cache.options.lastModified?.toISOString() ?? "unknown"}
              </code>
            </span>
          </div>
        </div>
      </div>
    )
  }
</Layout>

<style>
  .error {
    text-align: center;
    padding: 6rem 0;
    color: #71717a;
  }

  .error a {
    color: #d97706;
    margin-top: 1rem;
    display: inline-block;
    font-size: 0.875rem;
  }

  .back {
    color: #52525b;
    text-decoration: none;
    font-size: 0.8rem;
    display: inline-block;
    margin-bottom: 2.5rem;
    letter-spacing: 0.02em;
    transition: color 0.2s;
  }

  .back:hover {
    color: #fafaf9;
  }

  .product-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: start;
  }

  @media (max-width: 768px) {
    .product-layout {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
  }

  .product-image {
    overflow: hidden;
    border-radius: 0.75rem;
    aspect-ratio: 4 / 5;
    background: #18181b;
  }

  .product-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .product-info {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    padding-top: 1rem;
  }

  .category {
    font-size: 0.65rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #d97706;
  }

  h1 {
    font-family: var(--font-display), Georgia, serif;
    font-size: 2.75rem;
    font-weight: 700;
    line-height: 1.1;
    color: #fafaf9;
    letter-spacing: -0.02em;
  }

  .description {
    color: #71717a;
    font-size: 1rem;
    line-height: 1.75;
  }

  .price-block {
    display: flex;
    align-items: baseline;
    gap: 1.25rem;
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
  }

  .price {
    font-family: var(--font-display), Georgia, serif;
    font-size: 2rem;
    font-weight: 700;
    color: #fafaf9;
  }

  .stock {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .stock.in {
    color: #4ade80;
  }

  .stock.out {
    color: #f87171;
  }

  .disabled-btn {
    padding: 1rem 2rem;
    background: rgba(255, 255, 255, 0.04);
    color: #52525b;
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: 0.5rem;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: not-allowed;
    width: 100%;
    font-family: var(--font-body), system-ui, sans-serif;
  }

  .debug {
    margin-top: 4rem;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
    padding-top: 1rem;
  }

  .debug-inner {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    font-size: 0.75rem;
    color: #71717a;
    flex-wrap: wrap;
  }

  .debug-label {
    background: rgba(255, 255, 255, 0.06);
    color: #a1a1aa;
    padding: 0.2rem 0.5rem;
    border-radius: 0.25rem;
    font-weight: 600;
    font-size: 0.65rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .debug code {
    color: #a1a1aa;
    font-size: 0.7rem;
  }
</style>
